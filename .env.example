# ============================================
# DevManga 项目环境变量配置示例
# ============================================
# 复制此文件为 .env.development 和 .env.production
# 然后填入你自己的配置信息

# ============================================
# 网站配置
# ============================================
DOCUSAURUS_URL=http://localhost:3000
SITE_BASE_URL=/

# ============================================
# GitHub 配置
# ============================================
GITHUB_USERNAME=laby-umr
GITHUB_REPO=laby-blog
GITHUB_URL=https://github.com/laby-umr
GITHUB_PAGES_URL=https://laby.top

# ============================================
# Giscus 评论系统配置
# ============================================
# 获取方式：https://giscus.app/zh-CN
GISCUS_REPO=your-username/your-repo
GISCUS_REPO_ID=your_repo_id
GISCUS_CATEGORY=Announcements
GISCUS_CATEGORY_ID=your_category_id

# ============================================
# Supabase 配置
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_EDGE_FUNCTION_URL=https://your-project-id.supabase.co/functions/v1/dynamic-processor

# ============================================
# Resend 邮件服务配置
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================
# 联系表单配置
# ============================================
# 联系表单邮件接收地址
CONTACT_EMAIL=your-email@example.com

# ============================================
# 域名配置
# ============================================
DOMAIN=your-domain.com
EMAIL_FROM=noreply@your-domain.com

# ============================================
# 博客 API 配置（可选）
# ============================================
BLOG_API_URL=http://your-blog-api-server:port

# ============================================
# 网易云音乐 API 配置（可选）
# ============================================
NETEASE_API_URL=http://your-netease-api-server:port

# ============================================
# 项目展示 URL 配置（可选）
# ============================================
PROJECT_ENGLISH_LEARNING_URL=http://your-project-url
PROJECT_CRM_URL=http://your-project-url
PROJECT_SUMMER_CAMP_URL=http://your-project-url
PROJECT_COFFEE_SHOP_URL=http://your-project-url
PROJECT_DATA_VIZ_URL=http://your-project-url
